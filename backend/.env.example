# ─── AI ──────────────────────────────────────────────────────────────────────
# OpenRouter API Key (free — get it at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
AI_MODEL=google/gemma-2-9b-it

# ─── Real-Time News Search ─────────────────────────────────────────────────────
# Google Search API key (for live news context — see DEPLOYMENT.md for setup)
# NOTE: If not set, the app still works but without real-time news grounding
GOOGLE_SEARCH_API_KEY=paste-your-google-search-api-key-here
GOOGLE_SEARCH_CX=paste-your-custom-search-cx-here

# ─── Database ─────────────────────────────────────────────────────────────────
# Firebase Service Account (for Firestore report history)
# Teammate will provide this. Not required for local AI testing.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:5173
